{
  "name": "odonto-panel-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Odonto desktop dashboard shell",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.cspgabriel.odonto.panel",
    "productName": "Odonto Painel",
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Odonto-Painel-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
