# ─── Supabase (Auth + Database) ─────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Direct Postgres for Drizzle ────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string
# 1) Use "Transaction" pooler (port 6543) for app queries — add ?pgbouncer=true
# 2) Replace [YOUR-PASSWORD] with your database password
# 3) Optional: SQL Editor → ALTER ROLE postgres SET statement_timeout = '60s';
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: Direct connection (Session mode, port 5432) for migrations/seeds only
# Get from: Settings → Database → Connection string → Session mode
# DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# ─── Supabase Service Role ───────────────────────────────────
# Required for storage bucket setup and admin operations
# Supabase Dashboard → Settings → API → service_role key
# NEVER expose in client code or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App Configuration ─────────────────────────────────────
# Base URL for teeth images (odontogram)
# TEETH_IMAGES_BASE_URL=https://your-domain.com/teeth

# Secret to protect /api/cron/cleanup-auth. Generate a random string.
CRON_SECRET=your-random-secret

# ─── Resend (Email) ────────────────────────────────────────
# API key for transactional emails (signup, password reset, etc.)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx

# ─── Site URL (required for auth redirects) ─────────────────
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com
# In Vercel: Project Settings → Environment Variables
# Set different values per environment (Production / Preview / Dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Demo & Development ─────────────────────────────────────
# Password for demo accounts created by npm run db:seed
# Default: Demo123! — change for production
DEMO_PASSWORD=Demo123!

# Enable [CareNova] debug logs in terminal
# Use 1 for dev, remove or set 0 for production
# CARENOVA_DEBUG=1

# Dev-only: bypass Envato verification locally
# NEVER set this in production
# LICENSE_TEST_CODE=carenova-dev-2026

# ─── Local license bypass ──────────────────────────────────
# Dev/test only. Remove for production.
LICENSE_TEST_CODE=carenova-dev-2026
